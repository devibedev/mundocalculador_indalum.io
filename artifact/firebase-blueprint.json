{
  "entities": {
    "Price": {
      "title": "Price",
      "description": "Price override for a product",
      "type": "object",
      "properties": {
        "unitPrice": { "type": "number" },
        "type": { "type": "string" },
        "lastUpdated": { "type": "string" }
      },
      "required": ["unitPrice", "type"]
    },
    "CartItem": {
      "title": "CartItem",
      "description": "An item in the cart or project",
      "type": "object",
      "properties": {
        "codigo": { "type": "string" },
        "nombre": { "type": "string" },
        "tipo": { "type": "string" },
        "cantidad": { "type": "number" },
        "metros": { "type": "number" },
        "esPorMetro": { "type": "boolean" },
        "precioUnitario": { "type": "number" },
        "total": { "type": "number" },
        "kerfIncluded": { "type": "boolean" }
      },
      "required": ["codigo", "nombre", "cantidad", "total"]
    },
    "Project": {
      "title": "Project",
      "description": "A saved project with multiple items",
      "type": "object",
      "properties": {
        "nombre": { "type": "string" },
        "fecha": { "type": "string" },
        "items": { 
          "type": "array",
          "items": { "$ref": "CartItem" }
        },
        "total": { "type": "number" }
      },
      "required": ["nombre", "fecha", "items", "total"]
    },
    "AppNote": {
      "title": "AppNote",
      "description": "A personal note or reminder",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "fecha": { "type": "string" }
      },
      "required": ["content", "fecha"]
    },
    "CalculationHistory": {
      "title": "CalculationHistory",
      "description": "Record of a calculation performed",
      "type": "object",
      "properties": {
        "fecha": { "type": "string" },
        "serie": { "type": "string" },
        "config": { "type": "string" },
        "width": { "type": "number" },
        "height": { "type": "number" }
      },
      "required": ["fecha", "serie", "config", "width", "height"]
    }
  },
  "firestore": {
    "/users/{userId}/prices/{productCode}": {
      "schema": "Price",
      "description": "User specific price overrides"
    },
    "/users/{userId}/projects/{projectId}": {
      "schema": "Project",
      "description": "Saved user projects"
    },
    "/users/{userId}/notes/{noteId}": {
      "schema": "AppNote",
      "description": "User personal notes"
    },
    "/users/{userId}/history/{historyId}": {
      "schema": "CalculationHistory",
      "description": "Calculation logs"
    },
    "/users/{userId}/cart/{cartItemId}": {
      "schema": "CartItem",
      "description": "Items in the current session cart"
    }
  }
}
